        given-names: "Terje O."
      - family-names: "Genz"
        given-names: "Alan"
    title: "DECUHR: An Algorithm for Automatic Integration of Singular Functions over a Hyperrectangular Region"
    journal: "Numerical Algorithms"
    volume: 8
    year: 1994
    start: 201
    end: 220
